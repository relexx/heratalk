{
    "name": "Android Development",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "."
    },
    "runArgs": [
        "--init"
    ],
    "remoteEnv": {
        "ADB_SERVER_SOCKET": "tcp:host.docker.internal:5037"
    },

    // Fully isolated: project files live in a named Docker volume — no host bind-mount.
    // On first open, use VS Code's "Clone Repository in Container Volume" or
    // create a new project inside /workspace from the integrated terminal.
    "workspaceMount": "source=android-dev-workspace,target=/workspace,type=volume",
    "workspaceFolder": "/workspace",

    "customizations": {
        "vscode": {
            "extensions": [
                "fwcd.kotlin",
                "vscjava.vscode-java-pack",
                "naco-siren.gradle-language",
                "redhat.vscode-xml",
                "eamodio.gitlens",
                "anthropic.claude-code",
                "drblury.protobuf-vsc",
                "DavidAnson.vscode-markdownlint",
                "tamasfe.even-better-toml",
                "streetsidesoftware.code-spell-checker",
                "streetsidesoftware.code-spell-checker-german"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "editor.formatOnSave": true,
                "files.trimTrailingWhitespace": true,
                "files.eol": "\n",
                // Suppress Java extension's JDK download prompt (JDK 21 is in the image)
                "java.configuration.detectJdksAtStart": false,
                "editor.tabSize": 4,
                "editor.rulers": [
                    120
                ],
                "files.insertFinalNewline": true,
                "[kotlin]": {
                    "editor.defaultFormatter": "fwcd.kotlin"
                },
                "kotlin.languageServer.enabled": true,
                "gradle.nestedProjects": true
            }
        }
    },

    // Claude Code native binary installed per-user in postCreateCommand
    "postCreateCommand": "bash /usr/local/share/devcontainer-post-create.sh",
    "postStartCommand": "bash /usr/local/share/devcontainer-post-start.sh",
    "remoteUser": "vscode",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": true,
            "configureZshAsDefaultShell": false
        },
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },

    // Full isolation: no additional host mounts beyond the workspace volume above
    "mounts": []
}